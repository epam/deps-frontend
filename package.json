  "scripts": {
    "start": "cross-env NODE_ENV=development node -r esm ./node_modules/webpack/bin/webpack.js serve --config ./config/webpack.dev.js",
    "build": "cross-env NODE_ENV=production node --expose-gc -r esm ./node_modules/webpack/bin/webpack.js --config ./config/webpack.prod.js",
    "test:manual": "node --trace-warnings --unhandled-rejections=strict ./node_modules/jest/bin/jest.js --colors --expand --errorOnDeprecated --watch --config ./config/jest.config.js --verbose",
    "test:auto": "node --trace-warnings --unhandled-rejections=strict ./node_modules/jest/bin/jest.js --colors --expand --errorOnDeprecated --coverage --config ./config/jest.config.js",
    "test:ci": "cat /etc/os-release && node -v && node --expose-gc --trace-warnings --unhandled-rejections=strict ./node_modules/jest/bin/jest.js --bail --ci --colors --expand --errorOnDeprecated --coverage --config ./config/jest.config.js --reporters=default --reporters=jest-junit --maxWorkers=1 --forceExit --logHeapUsage",
    "test:debug": "node --inspect-brk ./node_modules/jest/bin/jest.js --runInBand --colors --expand --errorOnDeprecated --watch --config ./config/jest.config.js",
    "eslint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "eslint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "stylelint": "stylelint ./src/**/*.css ./src/**/*.styles.js",
    "stylelint:fix": "stylelint ./src/**/*.css ./src/**/*.styles.js --fix",
    "lint": "yarn run eslint && yarn run stylelint",
    "lint:fix": "yarn run eslint:fix && yarn run stylelint:fix",
    "do:component": "bash ./scripts/create.sh components",
    "do:container": "bash ./scripts/create.sh containers"
  },
